# ----------------------------------------------------------------------------
# CourtReach environment variables
# Copy this file to .env and fill in the values. Never commit your real .env.
# ----------------------------------------------------------------------------

# --- Core ---
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Local install example: postgresql://postgres:postgres@localhost:5432/courtreach
# Or a free cloud Postgres (e.g. Neon): postgresql://user:pass@host/db?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/courtreach?schema=public"

# --- Redis (BullMQ job queue) ---
# Local: redis://localhost:6379
# Or a free cloud Redis (e.g. Upstash): rediss://default:pass@host:port
REDIS_URL="redis://localhost:6379"

# --- API server ---
API_PORT=4000
# Comma-separated list of allowed frontend origins for CORS
WEB_ORIGIN="http://localhost:3000"

# --- Auth ---
# Generate a long random string, e.g. `openssl rand -hex 32`
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- AI provider (choose one; OpenAI used by default) ---
AI_PROVIDER="openai"            # "openai" | "anthropic"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_MODEL="gpt-4o-mini"

# --- Contact finder (Hunter.io) ---
HUNTER_API_KEY=""

# --- Discovery (Overpass API - free, no key needed) ---
OVERPASS_URLS="https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter,https://maps.mail.ru/osm/tools/overpass/api/interpreter,https://overpass.openstreetmap.ru/api/interpreter"

# --- Email sending (SMTP via Nodemailer) ---
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_NAME="CourtReach"
SMTP_FROM_EMAIL=""

# --- Reply detection (IMAP polling) ---
IMAP_HOST=""
IMAP_PORT=993
IMAP_USER=""
IMAP_PASS=""

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
