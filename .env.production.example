# ----------------------------------------------------------------------------
# CourtReach — PRODUCTION environment variables
# Set these as environment variables in AWS App Runner (not as a file).
# Never commit real secrets to git.
# ----------------------------------------------------------------------------

NODE_ENV=production

# --- Database (Neon free tier: https://neon.tech) ---
# Create a project, copy the connection string from the Neon dashboard.
# Make sure to append ?sslmode=require at the end.
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/courtreach?sslmode=require"

# --- Redis (Upstash free tier: https://upstash.com) ---
# Create a Redis database, copy the TLS URL from the Upstash dashboard.
REDIS_URL="rediss://default:pass@us1-xxx.upstash.io:6379"

# --- API server ---
API_PORT=4000
# Set to the App Runner URL of the courtreach-web service (no trailing slash).
# Update this after the web service is deployed.
WEB_ORIGIN="https://your-web-service.us-east-1.awsapprunner.com"

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# --- AI provider ---
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY=""
# GOOGLE_AI_API_KEY=""
AI_MODEL="claude-sonnet-4-6"

# --- Contact finder (Hunter.io) ---
HUNTER_API_KEY="your-hunter-api-key"

# --- Discovery (Overpass API - free, no key needed) ---
OVERPASS_URLS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter,https://maps.mail.ru/osm/tools/overpass/api/interpreter,https://overpass.openstreetmap.ru/api/interpreter

# --- Email sending (SMTP) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_NAME="CourtReach"
SMTP_FROM_EMAIL="your-email@gmail.com"

# --- Reply detection (IMAP; optional) ---
# IMAP_HOST=
# IMAP_PORT=993
# IMAP_USER=
# IMAP_PASS=

# ----------------------------------------------------------------------------
# Frontend (apps/web) — set on the courtreach-web App Runner service only
# This is also passed as a Docker build ARG when building the web image:
#   docker build --build-arg NEXT_PUBLIC_API_URL=https://... -f apps/web/Dockerfile .
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="https://your-api-service.us-east-1.awsapprunner.com"
