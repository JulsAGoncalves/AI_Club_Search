{
  "name": "@courtreach/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"server,worker\" --prefix-colors \"cyan,yellow\" \"cross-env NODE_OPTIONS=--use-system-ca tsx watch src/server.ts\" \"cross-env NODE_OPTIONS=--use-system-ca tsx watch src/worker.ts\"",
    "dev:worker": "cross-env NODE_OPTIONS=--use-system-ca tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --use-system-ca dist/server.js",
    "start:worker": "node --use-system-ca dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@courtreach/shared": "workspace:*",
    "@google/genai": "^2.10.0",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.13.2",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "imapflow": "^1.0.164",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.7.1",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.15",
    "openai": "^4.67.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mailparser": "^3.4.4",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.4",
    "@types/nodemailer": "^6.4.16",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
